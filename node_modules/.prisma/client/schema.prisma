// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

enum Role {
  ADMIN
  CUSTOMER
  KASIR
  KITCHEN
  DRIVER
}

enum OrderStatus {
  PENDING
  CONFIRMED
  COOKING
  READY
  DELIVERING
  COMPLETED
  CANCELLED
}

enum OrderSource {
  APP
  CHATBOT
  QR
}

enum PaymentMethod {
  CASH
  TRANSFER
  EWALLET
}

enum PaymentStatus {
  UNPAID
  PAID
  REFUNDED
}

enum TableStatus {
  AKTIF
  NONAKTIF
}

model User {
  id        BigInt   @id @default(autoincrement())
  name      String   @db.VarChar(255)
  email     String   @unique @db.VarChar(255)
  password  String   @db.VarChar(255)
  role      Role     @default(CUSTOMER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  carts           Cart[]
  orders          Order[]
  deliveries      Delivery[]
  chatbotLogs     ChatbotLog[]
  chatbotSessions ChatbotSession[]

  @@map("users")
}

model Category {
  id    BigInt @id @default(autoincrement())
  name  String @db.VarChar(255)
  menus Menu[]

  @@map("categories")
}

model Menu {
  id          BigInt   @id @default(autoincrement())
  categoryId  BigInt   @map("category_id")
  name        String   @db.VarChar(255)
  price       Decimal  @db.Decimal(10, 2)
  description String?  @db.Text
  image       String?  @db.VarChar(255)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category   Category    @relation(fields: [categoryId], references: [id])
  cartItems  CartItem[]
  orderItems OrderItem[]

  @@map("menus")
}

model Cart {
  id             BigInt   @id @default(autoincrement())
  userId         BigInt?  @map("user_id")
  guestSessionId BigInt?  @map("guest_session_id")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user         User?         @relation(fields: [userId], references: [id])
  guestSession GuestSession? @relation(fields: [guestSessionId], references: [id])
  items        CartItem[]

  @@map("carts")
}

model CartItem {
  id     BigInt @id @default(autoincrement())
  cartId BigInt @map("cart_id")
  menuId BigInt @map("menu_id")
  qty    Int

  cart Cart @relation(fields: [cartId], references: [id])
  menu Menu @relation(fields: [menuId], references: [id])

  @@map("cart_items")
}

model Order {
  id             BigInt      @id @default(autoincrement())
  userId         BigInt?     @map("user_id")
  tableId        BigInt?     @map("table_id")
  guestSessionId BigInt?     @map("guest_session_id")
  orderSource    OrderSource @map("order_source")
  status         OrderStatus @default(PENDING)
  totalPrice     Decimal     @map("total_price") @db.Decimal(10, 2)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  user         User?         @relation(fields: [userId], references: [id])
  table        Table?        @relation(fields: [tableId], references: [id])
  guestSession GuestSession? @relation(fields: [guestSessionId], references: [id])
  items        OrderItem[]
  payments     Payment[]
  deliveries   Delivery[]

  @@map("orders")
}

model OrderItem {
  id      BigInt  @id @default(autoincrement())
  orderId BigInt  @map("order_id")
  menuId  BigInt  @map("menu_id")
  qty     Int
  price   Decimal @db.Decimal(10, 2)

  order Order @relation(fields: [orderId], references: [id])
  menu  Menu  @relation(fields: [menuId], references: [id])

  @@map("order_items")
}

model Payment {
  id      BigInt        @id @default(autoincrement())
  orderId BigInt        @map("order_id")
  method  PaymentMethod
  status  PaymentStatus @default(UNPAID)
  amount  Decimal       @db.Decimal(10, 2)
  paidAt  DateTime?     @map("paid_at")

  order Order @relation(fields: [orderId], references: [id])

  @@map("payments")
}

model Delivery {
  id       BigInt @id @default(autoincrement())
  orderId  BigInt @map("order_id")
  driverId BigInt @map("driver_id")
  status   String @db.VarChar(50) // e.g., delivering, done

  order  Order @relation(fields: [orderId], references: [id])
  driver User  @relation(fields: [driverId], references: [id])

  @@map("deliveries")
}

model Table {
  id     BigInt      @id @default(autoincrement())
  name   String      @db.VarChar(255)
  qrCode String?     @map("qr_code") @db.Text
  status TableStatus @default(AKTIF)

  orders        Order[]
  guestSessions GuestSession[]

  @@map("tables")
}

model GuestSession {
  id        BigInt   @id @default(autoincrement())
  tableId   BigInt   @map("table_id")
  token     String   @unique @db.VarChar(255)
  createdAt DateTime @default(now())
  expiresAt DateTime @map("expires_at")

  table  Table   @relation(fields: [tableId], references: [id])
  carts  Cart[]
  orders Order[]

  @@map("guest_sessions")
}

model ChatbotLog {
  id        BigInt   @id @default(autoincrement())
  userId    BigInt?  @map("user_id")
  message   String   @db.Text
  response  String   @db.Text
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@map("chatbot_logs")
}

model ChatbotSession {
  id        BigInt   @id @default(autoincrement())
  userId    BigInt?  @map("user_id")
  sessionId String   @unique @map("session_id") @db.VarChar(255)
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@map("chatbot_sessions")
}

model Voucher {
  id        BigInt   @id @default(autoincrement())
  code      String   @unique @db.VarChar(50)
  discount  Decimal  @db.Decimal(10, 2)
  expiredAt DateTime @map("expired_at")

  @@map("vouchers")
}
